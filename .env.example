# ──────────────────────────────────────────────────────────────
# Pavlova Love Tampa — environment variables
# Copy this file to ".env" and fill in your own values.
# All values are read at runtime, so the same build works anywhere.
# ──────────────────────────────────────────────────────────────

# ── Supabase (required for dynamic data on Vercel / production) ──
# Project Settings → API: Project URL + service_role key (secret, server-only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Admin panel login (/admin) ──
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
# Secret used to sign the admin session cookie. Use a long random string.
SESSION_SECRET=please-change-to-a-long-random-string

# ── Square online payments (required — checkout has no pay-at-pickup fallback) ──
SQUARE_ACCESS_TOKEN=
SQUARE_APPLICATION_ID=
SQUARE_LOCATION_ID=
# "sandbox" for testing, "production" for live payments
SQUARE_ENVIRONMENT=sandbox
# Production access token must include ORDERS_WRITE + PAYMENTS_WRITE scopes
# so website orders appear in Square POS with line items (not just a bare payment).
# Apple Pay additionally requires registering this domain in the Square Developer
# Dashboard (Apple Pay settings) and hosting the verification file it gives you at
# public/.well-known/apple-developer-merchantid-domain-association (HTTPS only,
# no effect on localhost). Google Pay needs no extra setup beyond the keys above.

# ── Google Business reviews (homepage + /reviews) ──
# Enable "Places API (New)" in Google Cloud Console.
# Place ID: Google Maps → your business → Share → find ChIJ... ID, or use Place ID Finder.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# ── Resend email notifications ──
# 1. Create an API key at https://resend.com/api-keys
# 2. Verify your domain (or use onboarding@resend.dev for testing only)
# 3. Set all three on Vercel → Settings → Environment Variables → Production
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=Pavlova Love Tampa <orders@pavlovalovetampa.com>
# Inbox for order + form alerts (defaults to Business Email in admin settings)
NOTIFY_EMAIL=hello@pavlovalovetampa.com

# ── Twilio SMS (optional — order confirmation texts to customer phone) ──
# 1. Sign up at https://www.twilio.com and buy a US phone number
# 2. Console → Account → API keys & tokens
# 3. Add all three on Vercel → Settings → Environment Variables → Production
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+18135550100
