---
import MainLayout from '@/layouts/MainLayout.astro';
import MenuPage from '@/components/menu/MenuPage.tsx';
import { detectLang, useTranslations } from '@/i18n/utils';
import { COL, listAll } from '@/server/store';

const lang = detectLang(Astro.request.headers.get('cookie'));
const { t } = useTranslations(lang);

let products: any[] = [];
let categories: any[] = [];
try {
  [products, categories] = await Promise.all([
    listAll(COL.products, { orderBy: 'sortOrder', dir: 'asc' }),
    listAll(COL.categories, { orderBy: 'sortOrder', dir: 'asc' }),
  ]);
} catch (_) {}

const catSlug = new Map<number, string>(categories.map((c: any) => [c.id, c.slug || String(c.id)]));

const tabs = categories.map((c: any) => ({ id: c.slug || String(c.id), en: c.name, es: c.nameEs || c.name }));

const items = products
  .filter((p: any) => p.available !== false)
  .map((p: any) => ({
    id: p.id,
    cat: catSlug.get(p.categoryId) || 'all',
    name: p.name,
    nameEs: p.nameEs || p.name,
    price: Number(p.price),
    desc: p.description || '',
    descEs: p.descriptionEs || p.description || '',
    image: p.imageUrl || '',
  }));

const featuredProduct = products.find((p: any) => p.featured) || products[0] || null;
const featured = featuredProduct
  ? {
      id: featuredProduct.id,
      name: featuredProduct.name,
      nameEs: featuredProduct.nameEs || featuredProduct.name,
      price: Number(featuredProduct.price),
      image: featuredProduct.imageUrl || '',
      desc: featuredProduct.description || '',
      descEs: featuredProduct.descriptionEs || featuredProduct.description || '',
    }
  : null;
---

<MainLayout
  title={t('menu.title')}
  description={lang === 'es'
    ? 'Menú diario de Pavlova Love Tampa — arepas, pavlovas y cocina latina fresca cada día.'
    : "Pavlova Love Tampa's daily menu — fresh arepas, pavlovas, and Latin kitchen specials every day."}
>
  <MenuPage lang={lang} items={items} tabs={tabs} featured={featured} client:load />
</MainLayout>
