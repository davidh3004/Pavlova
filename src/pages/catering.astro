---
import MainLayout from '@/layouts/MainLayout.astro';
import { detectLang, useTranslations } from '@/i18n/utils';
import CateringForm from '@/components/forms/CateringForm';

const lang = detectLang(Astro.request.headers.get('cookie'));
const { t } = useTranslations(lang);
const es = lang === 'es';

const assurances = [
  {
    // Clock with counter-clockwise arrow (history / schedule)
    paths: ['M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8', 'M3 3v5h5', 'M12 7v5l4 2'],
    title: es ? 'Consulta Disponibilidad' : 'Check Availability',
    desc: es
      ? 'Recomendamos reservar con 4-6 semanas de anticipación para eventos grandes.'
      : 'We recommend booking 4-6 weeks in advance for large events.',
  },
  {
    // Crossed fork & knife (utensils-crossed)
    paths: [
      'm16 2-2.3 2.3a3 3 0 0 0 0 4.2l1.8 1.8a3 3 0 0 0 4.2 0L22 8',
      'M15 15 3.3 3.3a4.2 4.2 0 0 0 0 6l7.3 7.3c.7.7 2 .7 2.8 0L15 15Zm0 0 7 7',
      'm2.1 21.8 6.4-6.3',
      'm19 5-7 7',
    ],
    title: es ? 'Degustaciones Personalizadas' : 'Custom Tastings',
    desc: es
      ? 'Cortesía para eventos que superen los 100 invitados.'
      : 'Complimentary for events exceeding 100 guests.',
  },
];

const galleryImages = [
  { src: '/gallery/catering-quinceanera-table.jpg', altEn: 'Quinceañera dessert table', altEs: 'Mesa de quinceañera' },
  { src: '/gallery/catering-berry-parfaits.jpg', altEn: 'Catering berry parfait cups', altEs: 'Vasitos de parfait para catering' },
  { src: '/gallery/catering-quinceanera-wide.jpg', altEn: 'Event catering dessert display', altEs: 'Exhibición de catering para eventos' },
  { src: '/gallery/birthday-pavlova-flowers.jpg', altEn: 'Celebration pavlova with flowers', altEs: 'Pavlova de celebración con flores' },
  { src: '/gallery/birthday-pavlova-gold-topper.jpg', altEn: 'Birthday strawberry pavlova', altEs: 'Pavlova de cumpleaños' },
  { src: '/gallery/birthday-pavlova-number-8.jpg', altEn: 'Custom number pavlova', altEs: 'Pavlova personalizada en número' },
];
---

<MainLayout
  title={t('catering.title')}
  description={es
    ? 'Catering profesional venezolano para eventos en Tampa — desde bodas hasta eventos corporativos.'
    : 'Professional Venezuelan catering for events in Tampa — weddings, corporate, birthday parties and more.'}
>

  <!-- ════════ HERO — full-bleed catering showcase ════════ -->
  <section class="relative overflow-hidden min-h-[52vh] lg:min-h-[58vh] -mt-24 lg:-mt-28 pt-24 lg:pt-28 flex items-end">
    <div class="absolute inset-0">
      <img src="/gallery/catering-quinceanera-wide.jpg" alt={es ? 'Mesa de catering para eventos' : 'Event catering dessert display'} class="w-full h-full object-cover object-center scale-[0.92] md:scale-100" loading="eager" />
      <div class="absolute inset-0 bg-[linear-gradient(180deg,oklch(30%_0.09_358_/_0.55)_0%,oklch(24%_0.06_358_/_0.82)_55%,oklch(22%_0.05_358_/_0.92)_100%)]"></div>
    </div>
    <div class="relative z-10 container-lux pb-14 lg:pb-20 pt-8">
      <p class="eyebrow text-white/75 mb-4">{es ? 'Catering y Eventos' : 'Catering & Events'}</p>
      <h1 class="font-serif text-4xl sm:text-5xl lg:text-[3.5rem] leading-[1.05] text-white max-w-2xl mb-4">
        {es ? 'Endulzamos Tus' : 'We Sweeten Your'}<br/>
        <span class="text-script text-[var(--blush)]!">{es ? 'Celebraciones' : 'Celebrations'}</span>
      </h1>
      <p class="text-white/75 max-w-lg text-sm lg:text-base leading-relaxed">
        {es
          ? 'Desde quinceañeras hasta eventos corporativos — mesas de postres, pavlovas personalizadas y catering latino hecho con amor.'
          : 'From quinceañeras to corporate gatherings — dessert tables, custom pavlovas, and Latin catering made with love.'}
      </p>
    </div>
  </section>

  <!-- ════════ INQUIRE ABOUT YOUR EVENT ════════ -->
  <section id="inquire" class="bg-base-100 pt-10 lg:pt-14 pb-14 lg:pb-24 scroll-mt-24">
    <div class="container-lux grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
      <div class="reveal reveal-1 max-w-lg mx-auto lg:mx-0 text-center lg:text-left">
        <p class="eyebrow text-[var(--cta)] mb-4">{es ? 'Creemos Algo Mágico' : 'Let\u2019s Create Magic'}</p>
        <h2 class="font-serif text-4xl lg:text-5xl leading-[1.05] text-base-content mb-5">
          {es ? 'Cuéntanos Sobre' : 'Inquire About'}<br/>{es ? 'Tu Evento' : 'Your Event'}
        </h2>
        <p class="text-base-content/65 leading-relaxed mb-8 max-w-md mx-auto lg:mx-0 text-sm">
          {es
            ? 'Nuestro equipo se dedica a brindar un servicio impecable desde la primera consulta hasta el último bocado. Cuéntanos tu visión y nosotros nos encargamos del resto.'
            : 'Our team is dedicated to providing white-glove service from the first consultation to the final bite. Tell us about your vision, and we will handle the rest.'}
        </p>
        <div class="space-y-5">
          {assurances.map((a) => (
            <div class="flex gap-4 text-left justify-center lg:justify-start">
              <div class="inline-grid place-items-center w-10 h-10 shrink-0 rounded-full bg-[var(--blush-soft)] text-[var(--cta)]">
                <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  {a.paths.map((p) => <path d={p}/>)}
                </svg>
              </div>
              <div>
                <h4 class="font-bold text-[0.9rem] text-base-content mb-0.5">{a.title}</h4>
                <p class="text-[0.82rem] text-base-content/55 leading-relaxed max-w-sm">{a.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="reveal reveal-2 bg-[var(--blush-soft)] rounded-[24px] p-7 lg:p-9">
        <CateringForm lang={lang} client:load />
      </div>
    </div>
  </section>

  <!-- ════════ CATERING GALLERY + VIDEO ════════ -->
  <section class="bg-base-100 border-t border-[var(--hairline)] py-14 lg:py-24">
    <div class="container-lux">
      <div class="text-center max-w-2xl mx-auto mb-10 lg:mb-14 reveal reveal-1">
        <p class="eyebrow text-[var(--cta)] mb-4">{es ? 'Nuestro Trabajo' : 'Our Work'}</p>
        <h2 class="font-serif text-3xl sm:text-4xl lg:text-[2.75rem] leading-[1.08] text-base-content mb-4">
          {es ? 'El Arte de la' : 'The Art of'}<br/>
          <span class="text-script text-[var(--cta)]!">{es ? 'Presentación' : 'Presentation'}</span>
        </h2>
        <p class="text-base-content/60 text-sm leading-relaxed">
          {es
            ? 'Mesas de postres, pavlovas personalizadas y catering latino para cada celebración.'
            : 'Dessert tables, custom pavlovas, and Latin catering crafted for every celebration.'}
        </p>
      </div>

      <!-- Mosaic: video 1×2 left, 6 images in 2 rows on the right -->
      <div class="presentation-mosaic reveal reveal-2" data-reveal>
        <div class="presentation-video overflow-hidden rounded-[var(--radius-box)] shadow-[var(--shadow-soft)] bg-neutral/5">
          <video
            class="catering-showcase-video w-full h-full object-cover pointer-events-none"
            autoplay
            muted
            loop
            playsinline
            disablepictureinpicture
            controlslist="nodownload nofullscreen noremoteplayback"
            aria-label={es ? 'Video de catering Pavlova Love Tampa' : 'Pavlova Love Tampa catering showcase video'}
          >
            <source src="/videos/catering.mp4" type="video/mp4" />
          </video>
        </div>

        {galleryImages.map((img) => (
          <div class="presentation-cell overflow-hidden rounded-[var(--radius-box)] shadow-[var(--shadow-soft)]">
            <img
              src={img.src}
              alt={es ? img.altEs : img.altEn}
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll('.catering-showcase-video').forEach((el) => {
      const video = el;
      video.muted = true;
      video.defaultMuted = true;
      video.setAttribute('playsinline', '');
      video.play().catch(() => {});
      video.addEventListener('contextmenu', (e) => e.preventDefault());
      document.addEventListener('visibilitychange', () => {
        if (!document.hidden) video.play().catch(() => {});
      });
    });
  </script>

  <style>
    /* 4×2 mosaic — video 1 col × 2 rows on the left, 6 images on the right */
    .presentation-mosaic {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: minmax(140px, 1fr);
      gap: 0.75rem;
    }

    .presentation-video {
      grid-column: 1 / -1;
      aspect-ratio: 16 / 9;
      min-height: 200px;
    }

    @media (min-width: 640px) {
      .presentation-mosaic {
        grid-template-columns: repeat(4, 1fr);
        grid-template-rows: repeat(2, minmax(0, 1fr));
        aspect-ratio: 2 / 1;
        gap: 1rem;
      }

      .presentation-video {
        grid-column: 1;
        grid-row: 1 / span 2;
        aspect-ratio: auto;
        min-height: 0;
      }

      .presentation-cell {
        min-height: 0;
      }
    }

    @media (min-width: 1024px) {
      .presentation-mosaic {
        gap: 1.25rem;
      }
    }
  </style>

</MainLayout>
