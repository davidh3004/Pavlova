---
import MainLayout from '@/layouts/MainLayout.astro';
import { detectLang, useTranslations } from '@/i18n/utils';
import CateringForm from '@/components/forms/CateringForm';

const lang = detectLang(Astro.request.headers.get('cookie'));
const { t } = useTranslations(lang);
const es = lang === 'es';

const packages = [
  {
    name: es ? 'El Brunch Latino' : 'The Latin Brunch',
    price: es ? '$32 / persona' : '$32 / guest',
    image: '/images/latin_food_plate.png',
    desc: es
      ? 'Un vibrante despliegue de media mañana con arepas, empanadas y fruta tropical fresca.'
      : 'A vibrant mid-morning spread of arepas, empanadas, and fresh tropical fruit.',
    features: es
      ? ['Mini arepas surtidas', 'Estación de fruta de temporada', 'Servicio de café venezolano']
      : ['Assorted mini arepas', 'Seasonal fruit display', 'Venezuelan coffee service'],
  },
  {
    name: es ? 'Dulces de Autor' : 'Signature Sweets',
    price: es ? '$24 / persona' : '$24 / guest',
    image: '/images/signature-cake.png',
    desc: es
      ? 'Nuestras pavlovas, tortas y pasteles más celebrados dispuestos como una elegante mesa de postres.'
      : 'Our most celebrated pavlovas, cakes, and pastries arranged as an elegant dessert table.',
    features: es
      ? ['Selección de mini pavlovas', 'Tres leches y marquesa', 'Estilismo de mesa de postres']
      : ['Mini pavlova selection', 'Tres leches & marquesa', 'Custom dessert-table styling'],
  },
  {
    name: es ? 'Gala Ejecutiva' : 'Executive Gala',
    price: es ? '$58 / persona' : '$58 / guest',
    image: '/images/catering_event.png',
    desc: es
      ? 'Una experiencia emplatada con servicio completo para celebraciones importantes y galas corporativas.'
      : 'A full-service plated experience for milestone celebrations and corporate galas.',
    features: es
      ? ['Cena emplatada de tres tiempos', 'Capitán de evento dedicado', 'Vajilla y mantelería completa']
      : ['Three-course plated dinner', 'Dedicated event captain', 'Full tableware & linens'],
  },
];

const assurances = [
  {
    // Clock with counter-clockwise arrow (history / schedule)
    paths: ['M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8', 'M3 3v5h5', 'M12 7v5l4 2'],
    title: es ? 'Consulta Disponibilidad' : 'Check Availability',
    desc: es
      ? 'Recomendamos reservar con 4-6 semanas de anticipación para eventos grandes.'
      : 'We recommend booking 4-6 weeks in advance for large events.',
  },
  {
    // Crossed fork & knife (utensils-crossed)
    paths: [
      'm16 2-2.3 2.3a3 3 0 0 0 0 4.2l1.8 1.8a3 3 0 0 0 4.2 0L22 8',
      'M15 15 3.3 3.3a4.2 4.2 0 0 0 0 6l7.3 7.3c.7.7 2 .7 2.8 0L15 15Zm0 0 7 7',
      'm2.1 21.8 6.4-6.3',
      'm19 5-7 7',
    ],
    title: es ? 'Degustaciones Personalizadas' : 'Custom Tastings',
    desc: es
      ? 'Cortesía para eventos que superen los 100 invitados.'
      : 'Complimentary for events exceeding 100 guests.',
  },
];
---

<MainLayout
  title={t('catering.title')}
  description={es
    ? 'Catering profesional venezolano para eventos en Tampa — desde bodas hasta eventos corporativos.'
    : 'Professional Venezuelan catering for events in Tampa — weddings, corporate, birthday parties and more.'}
>

  <!-- ════════ HERO ════════ -->
  <section class="relative bg-base-100 overflow-hidden">
    <!-- Background image -->
    <div class="absolute inset-0">
      <img
        src="/images/catering.png"
        alt={es ? 'Mesa de catering con pavlovas y postres' : 'Catering spread with pavlovas and pastries'}
        class="w-full h-full object-cover object-center"
      />
      <!-- White fade from the left -->
      <div class="absolute inset-0 bg-[linear-gradient(to_right,var(--color-base-100)_0%,var(--color-base-100)_26%,transparent_68%)]"></div>
      <!-- Subtle bottom fade to blend into next section -->
      <div class="absolute inset-x-0 bottom-0 h-28 bg-[linear-gradient(to_top,var(--color-base-100),transparent)]"></div>
    </div>

    <!-- Content -->
    <div class="relative container-lux flex items-center min-h-[580px] lg:min-h-[680px] py-20">
      <div class="reveal reveal-1 max-w-xl mx-auto md:mx-0 text-center md:text-left">
        <p class="eyebrow text-[var(--cta)] mb-5">{es ? 'Ocasiones Especiales' : 'Elevated Occasions'}</p>
        <h1 class="font-serif text-5xl lg:text-[3.9rem] leading-[1.03] text-base-content mb-6">
          {es ? 'Catering Artesanal para' : 'Artisan Catering for'}<br/>
          <span class="text-script">{es ? 'Momentos' : 'Unforgettable'}</span> {es ? 'Inolvidables' : 'Events'}
        </h1>
        <p class="text-base-content/70 leading-relaxed mb-9 max-w-md">
          {es
            ? 'Desde íntimos almuerzos corporativos hasta grandes celebraciones de boda, llevamos el alma de la repostería venezolana a tus momentos más preciados en Tampa.'
            : 'From intimate corporate luncheons to grand wedding celebrations, we bring the soul of Venezuelan patisserie to your most cherished moments in Tampa.'}
        </p>
        <div class="flex flex-wrap justify-center md:justify-start items-center gap-4">
          <a href="#inquire" class="inline-flex items-center justify-center rounded-full bg-[var(--cta)] text-white text-[0.7rem] font-bold tracking-[0.22em] uppercase px-9 h-12 hover:bg-[var(--cta-hover)] transition-colors shadow-lg shadow-black/10">
            {es ? 'Solicitar Ahora' : 'Inquire Now'}
          </a>
          <a href="#packages" class="inline-flex items-center justify-center rounded-full border border-[var(--cta)]/40 text-[var(--cta)] text-[0.7rem] font-bold tracking-[0.22em] uppercase px-9 h-12 hover:bg-[var(--cta)] hover:text-white hover:border-transparent transition-colors">
            {es ? 'Ver Paquetes' : 'View Packages'}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ CURATED EXPERIENCES ════════ -->
  <section id="packages" class="bg-base-100 py-20 lg:py-28 scroll-mt-24">
    <div class="container-lux">
      <div class="reveal text-center max-w-2xl mx-auto mb-14 lg:mb-16">
        <h2 class="font-serif text-4xl lg:text-5xl text-base-content mb-4">{es ? 'Experiencias a Medida' : 'Curated Experiences'}</h2>
        <p class="text-base-content/60 leading-relaxed">
          {es
            ? 'Diseñadas para deleitar los sentidos y simplificar tu proceso de planificación.'
            : 'Designed to delight the senses and simplify your planning process.'}
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8" data-reveal>
        {packages.map((p) => (
          <div class="flex flex-col rounded-[var(--radius-box)] overflow-hidden bg-base-100 border border-[var(--hairline)] shadow-[var(--shadow-soft)]">
            <div class="overflow-hidden">
              <img src={p.image} alt={p.name} class="w-full aspect-[4/3] object-cover" />
            </div>
            <div class="p-7 lg:p-8 flex flex-col flex-1">
              <div class="flex items-start justify-between gap-3 mb-3">
                <h3 class="font-serif text-2xl text-base-content leading-tight">{p.name}</h3>
                <span class="text-[0.8rem] font-bold tracking-wide text-[var(--cta)] whitespace-nowrap pt-1.5">{p.price}</span>
              </div>
              <p class="text-sm text-base-content/60 leading-relaxed mb-6">{p.desc}</p>
              <ul class="space-y-3 mb-8">
                {p.features.map((f) => (
                  <li class="flex items-start gap-3 text-sm text-base-content/75">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--cta)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0"><path d="M20 6 9 17l-5-5"/></svg>
                    {f}
                  </li>
                ))}
              </ul>
              <a href="#inquire" class="mt-auto inline-flex items-center justify-center rounded-full bg-[var(--cta)] text-white text-[0.66rem] font-bold tracking-[0.2em] uppercase h-11 px-6 hover:bg-[var(--cta-hover)] transition-colors">
                {es ? 'Elegir Este Paquete' : 'Select This Package'}
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════ THE ART OF PRESENTATION ════════ -->
  <section class="bg-base-100 py-20 lg:py-28">
    <div class="container-lux">
      <div class="reveal flex items-end justify-between flex-wrap gap-5 mb-12">
        <h2 class="font-serif text-4xl lg:text-5xl leading-[1.1] text-base-content">
          {es ? 'El Arte de la ' : 'The Art of '}<span class="text-script text-[var(--cta)]">{es ? 'Presentación' : 'Presentation'}</span>
        </h2>
        <a href="/gallery" class="text-[0.7rem] font-bold tracking-[0.2em] uppercase text-[var(--cta)] hover:text-base-content transition-colors inline-flex items-center gap-2">
          {es ? 'Ver la Galería' : 'Explore the Gallery'}
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <div class="grid md:grid-cols-2 gap-5" data-reveal>
        <div class="overflow-hidden rounded-[var(--radius-box)] shadow-[var(--shadow-soft)] h-72 md:h-[520px]">
          <img src="/images/catering_event.png" alt={es ? 'Montaje de evento' : 'Event styling'} class="w-full h-full object-cover" />
        </div>
        <div class="grid grid-rows-2 gap-5">
          <div class="overflow-hidden rounded-[var(--radius-box)] shadow-[var(--shadow-soft)] h-44 md:h-[250px]">
            <img src="/menu-images/profiterol.jpg" alt={es ? 'Profiteroles' : 'Profiteroles'} class="w-full h-full object-cover" />
          </div>
          <div class="overflow-hidden rounded-[var(--radius-box)] shadow-[var(--shadow-soft)] h-44 md:h-[250px]">
            <img src="/images/custom_cake.png" alt={es ? 'Pastel personalizado' : 'Custom cake'} class="w-full h-full object-cover" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ INQUIRE ABOUT YOUR EVENT ════════ -->
  <section id="inquire" class="bg-base-100 py-10 lg:py-20 scroll-mt-24">
    <div class="container-lux grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
      <div class="reveal reveal-1 max-w-lg mx-auto lg:mx-0 text-center lg:text-left">
        <p class="eyebrow text-[var(--cta)] mb-4">{es ? 'Creemos Algo Mágico' : 'Let\u2019s Create Magic'}</p>
        <h2 class="font-serif text-4xl lg:text-5xl leading-[1.05] text-base-content mb-5">
          {es ? 'Cuéntanos Sobre' : 'Inquire About'}<br/>{es ? 'Tu Evento' : 'Your Event'}
        </h2>
        <p class="text-base-content/65 leading-relaxed mb-8 max-w-md mx-auto lg:mx-0 text-sm">
          {es
            ? 'Nuestro equipo se dedica a brindar un servicio impecable desde la primera consulta hasta el último bocado. Cuéntanos tu visión y nosotros nos encargamos del resto.'
            : 'Our team is dedicated to providing white-glove service from the first consultation to the final bite. Tell us about your vision, and we will handle the rest.'}
        </p>
        <div class="space-y-5">
          {assurances.map((a) => (
            <div class="flex gap-4 text-left justify-center lg:justify-start">
              <div class="inline-grid place-items-center w-10 h-10 shrink-0 rounded-full bg-[var(--blush-soft)] text-[var(--cta)]">
                <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  {a.paths.map((p) => <path d={p}/>)}
                </svg>
              </div>
              <div>
                <h4 class="font-bold text-[0.9rem] text-base-content mb-0.5">{a.title}</h4>
                <p class="text-[0.82rem] text-base-content/55 leading-relaxed max-w-sm">{a.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="reveal reveal-2 bg-[var(--blush-soft)] rounded-[24px] p-7 lg:p-9">
        <CateringForm lang={lang} client:load />
      </div>
    </div>
  </section>

</MainLayout>
