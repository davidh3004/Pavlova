---
import AdminLogin from '@/components/admin/AdminLogin';
import '@/styles/global.css';

import { getAdminId } from '@/server/auth';
if (getAdminId(Astro.cookies)) return Astro.redirect('/admin/dashboard');
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Login | Pavlova Love</title>
    <meta name="robots" content="noindex" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Montserrat:wght@300;400;500;600;700&display=swap" />
    <link rel="icon" type="image/png" href="/images/logo-mark.png" />
  </head>
  <body class="min-h-screen flex items-center justify-center p-4 bg-[linear-gradient(160deg,var(--blush-soft)_0%,var(--color-base-100)_55%,var(--color-base-200)_100%)]">
    <AdminLogin client:load />
  </body>
</html>
