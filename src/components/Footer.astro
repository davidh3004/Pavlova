---
import { useTranslations, type Lang } from '@/i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const { t } = useTranslations(lang);
const es = lang === 'es';

const quickLinks = [
  { href: '/daily-menu', label: es ? 'Menú' : 'Menu' },
  { href: '/custom-orders', label: es ? 'Pedidos Especiales' : 'Custom Orders' },
  { href: '/about', label: es ? 'Nosotros' : 'About Us' },
  { href: '/contact', label: es ? 'Contacto' : 'Contact Us' },
];
---

<footer class="bg-neutral text-neutral-content mt-auto">
  <div class="container-lux py-16 lg:py-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-10">

      <!-- Brand -->
      <div class="lg:col-span-4">
        <img src="/images/logo-mark.png" alt="Pavlova Love Tampa" class="h-24 w-auto mb-6" />
        <p class="text-neutral-content/60 text-sm leading-relaxed max-w-xs mb-7">
          {es
            ? 'Repostería, café y cocina venezolana — hecha con amor en Tampa, FL.'
            : 'Venezuelan bakery, café & Latin kitchen — made with love in Tampa, FL.'}
        </p>
        <div class="flex gap-2.5">
          <a href="https://www.facebook.com/p/Pavlovalovetampa-100064058713044/" target="_blank" rel="noopener noreferrer"
            class="w-10 h-10 grid place-items-center rounded-full border border-neutral-content/15 text-neutral-content/70 hover:text-white hover:border-[var(--gold)] hover:bg-white/5 transition-all" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-[17px] w-[17px]" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://www.instagram.com/pavlovalovetampa/" target="_blank" rel="noopener noreferrer"
            class="w-10 h-10 grid place-items-center rounded-full border border-neutral-content/15 text-neutral-content/70 hover:text-white hover:border-[var(--gold)] hover:bg-white/5 transition-all" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-[17px] w-[17px]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://www.tiktok.com/@pavlovalovetampa0" target="_blank" rel="noopener noreferrer"
            class="w-10 h-10 grid place-items-center rounded-full border border-neutral-content/15 text-neutral-content/70 hover:text-white hover:border-[var(--gold)] hover:bg-white/5 transition-all" aria-label="TikTok">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-[17px] w-[17px]" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1.04-.1z"/></svg>
          </a>
          <a href="https://wa.me/14074197137" target="_blank" rel="noopener noreferrer"
            class="w-10 h-10 grid place-items-center rounded-full border border-neutral-content/15 text-neutral-content/70 hover:text-white hover:border-[var(--gold)] hover:bg-white/5 transition-all" aria-label="WhatsApp">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-[17px] w-[17px]" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/></svg>
          </a>
        </div>
      </div>

      <!-- Contact -->
      <div class="lg:col-span-3">
        <h3 class="eyebrow text-neutral-content/45 mb-5">{es ? 'Contacto' : 'Contact'}</h3>
        <ul class="space-y-3.5 text-sm">
          <li>
            <a href="https://maps.google.com/?q=3909+W+Broad+St+Tampa+FL+33614" target="_blank" rel="noopener noreferrer" class="flex items-start gap-3 text-neutral-content/65 hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mt-0.5 shrink-0 text-[var(--gold)]"><path d="M12 21s-7-5.5-7-11a7 7 0 0 1 14 0c0 5.5-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/></svg>
              <span>3909 W Broad St<br/>Tampa, FL 33614</span>
            </a>
          </li>
          <li>
            <a href="tel:+14074197137" class="flex items-center gap-3 text-neutral-content/65 hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="shrink-0 text-[var(--gold)]"><path d="M3 5a2 2 0 0 1 2-2h3l2 5-2.5 1.5a11 11 0 0 0 5 5L19 14l5 2v3a2 2 0 0 1-2 2A18 18 0 0 1 3 5z"/></svg>
              (407) 419-7137
            </a>
          </li>
          <li>
            <a href="mailto:hello@pavlovalovetampa.com" class="flex items-center gap-3 text-neutral-content/65 hover:text-white transition-colors break-all">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="shrink-0 text-[var(--gold)]"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
              hello@pavlovalovetampa.com
            </a>
          </li>
        </ul>
      </div>

      <!-- Hours -->
      <div class="lg:col-span-2">
        <h3 class="eyebrow text-neutral-content/45 mb-5">{t('footer.hours')}</h3>
        <ul class="space-y-2.5 text-sm text-neutral-content/65">
          <li>{t('contact.hoursDetail.weekday')}</li>
          <li>{t('contact.hoursDetail.saturday')}</li>
          <li>{t('contact.hoursDetail.sunday')}</li>
        </ul>
      </div>

      <!-- Quick Links -->
      <div class="lg:col-span-3">
        <h3 class="eyebrow text-neutral-content/45 mb-5">{t('footer.quickLinks')}</h3>
        <ul class="space-y-2.5">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-neutral-content/65 hover:text-white transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <hr class="hairline my-10" />
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-neutral-content/40">
      <p>© {new Date().getFullYear()} Pavlova Love Tampa. {t('footer.rights')}</p>  
    </div>
  </div>
</footer>
