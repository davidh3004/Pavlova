---
import '@/styles/global.css';

interface Props {
  title?: string;
  currentPath?: string;
}

const { title = 'Admin', currentPath = Astro.url.pathname } = Astro.props;

const navItems = [
  { href: '/admin/dashboard', label: 'Dashboard', paths: ['M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z'] },
  { href: '/admin/orders', label: 'Orders', paths: ['M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z', 'M3 6h18', 'M16 10a4 4 0 0 1-8 0'] },
  { href: '/admin/products', label: 'Products', paths: ['M2 21h20', 'M4 21v-8h16v8', 'M5 13V9a7 7 0 0 1 14 0v4', 'M12 2v3'] },
  { href: '/admin/menu', label: 'Daily Menu', paths: ['M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01'] },
  { href: '/admin/catering', label: 'Catering', paths: ['M4 20h16M6 20V10a6 6 0 0 1 12 0v10M12 4v2'] },
  { href: '/admin/custom-orders', label: 'Custom Orders', paths: ['m12 3 1.9 5.8L20 11l-6.1 2.2L12 19l-1.9-5.8L4 11l6.1-2.2z'] },
  { href: '/admin/reviews', label: 'Reviews', paths: ['m12 3 2.6 5.6 6.1.7-4.5 4.1 1.2 6L12 17.8 6.6 19.5l1.2-6L3.3 9.3l6.1-.7z'] },
  { href: '/admin/promotions', label: 'Promotions', paths: ['M20.59 13.41 13.42 20.58a2 2 0 0 1-2.83 0L2 12V2h10z', 'M7 7h.01'] },
  { href: '/admin/gallery', label: 'Gallery', paths: ['M3 5h18v14H3z', 'M3 15l5-5 4 4 3-3 6 6', 'M8.5 10a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3z'] },
  { href: '/admin/settings', label: 'Settings', paths: ['M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z', 'M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z'] },
];
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Pavlova Love Admin</title>
    <meta name="robots" content="noindex" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Montserrat:wght@300;400;500;600;700&display=swap" />
    <link rel="icon" type="image/png" href="/images/logo-mark.png" />
  </head>
  <body class="bg-base-200 min-h-screen">

    <div class="drawer lg:drawer-open min-h-screen">
      <input id="admin-drawer" type="checkbox" class="drawer-toggle" />

      <!-- Main content -->
      <div class="drawer-content flex flex-col">
        <!-- Top bar (mobile) -->
        <div class="navbar bg-base-100 border-b border-[var(--hairline)] lg:hidden sticky top-0 z-10">
          <label for="admin-drawer" class="btn btn-ghost btn-square drawer-button">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </label>
          <img src="/images/logo-mark.png" alt="Pavlova Love" class="h-10 w-auto ml-2" />
        </div>

        <main class="flex-1 p-4 lg:p-8">
          <div class="max-w-7xl mx-auto">
            <slot />
          </div>
        </main>
      </div>

      <!-- Sidebar -->
      <div class="drawer-side z-20">
        <label for="admin-drawer" aria-label="close sidebar" class="drawer-overlay"></label>
        <aside class="w-64 min-h-full bg-base-100 border-r border-[var(--hairline)] flex flex-col">
          <!-- Logo -->
          <div class="px-6 py-7 border-b border-[var(--hairline)]">
            <a href="/" class="flex items-center gap-3">
              <img src="/images/logo-mark.png" alt="Pavlova Love" class="h-11 w-auto" />
              <span class="block">
                <span class="block font-serif text-lg font-semibold leading-none text-base-content">Pavlova Love</span>
                <span class="block text-[0.6rem] tracking-[0.22em] uppercase text-[var(--rose)] font-semibold mt-1">Admin Panel</span>
              </span>
            </a>
          </div>

          <!-- Nav -->
          <nav class="flex-1 px-3 py-5">
            <ul class="flex flex-col gap-1">
              {navItems.map((item) => {
                const active = currentPath === item.href;
                return (
                  <li>
                    <a
                      href={item.href}
                      class={`flex items-center gap-3 rounded-[var(--radius-field)] px-3.5 py-2.5 text-sm font-medium transition-colors ${
                        active
                          ? 'bg-[var(--blush-soft)] text-[var(--cta)] font-semibold'
                          : 'text-base-content/65 hover:bg-[var(--blush-soft)]/60 hover:text-base-content'
                      }`}
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
                        {item.paths.map((d) => <path d={d} />)}
                      </svg>
                      <span>{item.label}</span>
                    </a>
                  </li>
                );
              })}
            </ul>
          </nav>

          <!-- Bottom actions -->
          <div class="p-4 border-t border-[var(--hairline)] space-y-2">
            <a href="/" class="flex items-center justify-center gap-2 rounded-[var(--radius-field)] h-10 text-[0.7rem] font-bold tracking-[0.16em] uppercase text-base-content/60 hover:text-base-content hover:bg-base-200 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
              View Site
            </a>
            <a href="/api/admin/logout" class="flex items-center justify-center gap-2 rounded-[var(--radius-field)] h-10 text-[0.7rem] font-bold tracking-[0.16em] uppercase border border-[var(--cta)]/40 text-[var(--cta)] hover:bg-[var(--cta)] hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9"/></svg>
              Logout
            </a>
          </div>
        </aside>
      </div>
    </div>

  </body>
</html>
